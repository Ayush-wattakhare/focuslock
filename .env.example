# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Google OAuth (for Supabase Auth)
# Get these from Google Cloud Console: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Anthropic API (for AI Coaching) - OPTIONAL & PAID SERVICE
# Get your API key from: https://console.anthropic.com/
# NOTE: This is a PAID service. The app works fully without it.
# AI coaching features will be disabled if this key is not provided.
# Pricing: https://www.anthropic.com/pricing
ANTHROPIC_API_KEY=your_anthropic_api_key

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cron Secret (for securing cron endpoints)
# Generate a secure random string for production
CRON_SECRET=your_secure_random_string

# Vercel Configuration (for production)
# These are automatically set by Vercel
# VERCEL_URL=
# VERCEL_ENV=
